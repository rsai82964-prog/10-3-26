#include <stdio.h>
#include <string.h>

int main()
{
    char str[100]="rahul";
    char str1[100]="RAHUL";
    char str2[100]="rahul";
    scanf("%s", str);

    strupr(str1);

    strlwr(str2);
    strrev(str3);

    printf("Uppercase string: %s\n", str1);
    printf("Lowercase string: %s\n", str2);
    printf("Reversed string: %s", str3);

    return 0;
}
