#include<stdio.h>
int main()
{
    int arr[]={1,0,-1,0,-2,2};
    int n=6,sum=0,i,j,k,l;

    for(i=0;i<n;i++)
    for(j=i+1;j<n;j++)
    for(k=j+1;k<n;k++)
    for(l=k+1;l<n;l++)
    {

        if(arr[i]+arr[j]+arr[k]+arr[l]==sum)
            printf("%d %d %d %d\n",arr[i],arr[j],arr[k],arr[l]);
    }
}
