#include<stdio.h>
int main()
{
    int arr[]={2,3,1,2,4,3};
    int n=6,S=7;
    int min=n+1,i,j,sum;

    for(i=0;i<n;i++)
    { 
        sum=0;
        for(j=i;j<n;j++)
        {
            sum+=arr[j];
            if(sum>=S)
            {
                if(j-i+1<min)
                    min=j-i+1;
                break;
            }
        }
    }

    printf("Minimum length = %d",min);
}
